{
  "name": "@turkish/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "tsc -p tsconfig.json && concurrently -n compile,server -c yellow,blue \"tsc -w -p tsconfig.json\" \"node --watch dist/index.js\"",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@turkish/shared": "*",
    "better-sqlite3": "^11.8.1",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "fast-glob": "^3.3.3"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.7",
    "typescript": "^5.7.3"
  }
}
